# API Configuration
REACT_APP_API_BASE_URL=http://localhost:3001
REACT_APP_API_TIMEOUT=10000

# Environment
REACT_APP_ENV=development

# Feature Flags
REACT_APP_ENABLE_LOGGING=true
REACT_APP_ENABLE_MOCK_IMAGES=true

# Logging Configuration
# LOG_LEVEL: Set the minimum log level (DEBUG, INFO, WARN, ERROR)
# Default: INFO
LOG_LEVEL=INFO

# ENABLE_DEBUG_LOGS: Enable all DEBUG level messages
# Default: false
ENABLE_DEBUG_LOGS=false

# SILENT_MODE: Suppress all logs except ERROR level
# Default: false
SILENT_MODE=false

# LOG_API_REQUESTS: Enable logging of API requests and responses
# Default: true
LOG_API_REQUESTS=true

# LOG_COMPONENT_LIFECYCLE: Enable logging of React component mount/unmount events
# Default: false
LOG_COMPONENT_LIFECYCLE=false

# LOG_PERFORMANCE: Enable performance metrics logging
# Default: true
LOG_PERFORMANCE=true
