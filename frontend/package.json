{
  "name": "frontend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\" \"e2e/**/*.{ts,js}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json}\" \"e2e/**/*.{ts,js}\"",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:e2e": "detox test --configuration ios.sim.debug",
    "test:e2e:android": "detox test --configuration android.emu.debug",
    "test:e2e:build:ios": "detox build --configuration ios.sim.debug",
    "test:e2e:build:android": "detox build --configuration android.emu.debug",
    "start": "expo start --port 8082",
    "web": "expo start --web --port 8082",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "build": "expo export:web"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.18.2",
    "@react-native-community/cli": "^11.3.6",
    "@react-native-community/cli-server-api": "^11.3.6",
    "@react-native-firebase/app": "^18.7.3",
    "@react-native-firebase/messaging": "^18.7.3",
    "@react-navigation/bottom-tabs": "^6.5.8",
    "@react-navigation/native": "^6.1.7",
    "@react-navigation/stack": "^6.3.17",
    "axios": "^1.13.5",
    "babel-preset-expo": "^9.5.0",
    "expo": "^49.0.23",
    "expo-linear-gradient": "~12.3.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.72.10",
    "react-native-biometrics": "^3.0.1",
    "react-native-paper": "^5.15.0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~3.3.0",
    "react-native-safe-area-context": "4.6.3",
    "react-native-screens": "~3.22.0",
    "react-native-share": "^10.2.1",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "~0.19.6",
    "react-native-worklets": "^0.7.4",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@expo/webpack-config": "^19.0.1",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~18.2.14",
    "@types/react-native": "^0.72.8",
    "@types/react-native-vector-icons": "^6.4.18",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "axios-mock-adapter": "^2.1.0",
    "babel-jest": "^30.2.0",
    "detox": "^20.13.0",
    "eslint": "^9.39.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-native": "^5.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "expo-cli": "^6.3.12",
    "fast-check": "^4.5.3",
    "jest": "^29.2.1",
    "jest-circus": "^30.2.0",
    "jest-environment-node": "^30.2.0",
    "prettier": "^3.8.1",
    "react-native-svg": "14.1.0",
    "react-test-renderer": "^18.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
