# Server Configuration
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# MongoDB Configuration
MONGODB_URL=mongodb://admin:password@localhost:27017/vc_did_db?authSource=admin
MONGO_USERNAME=admin
MONGO_PASSWORD=password

# RabbitMQ Configuration
RABBITMQ_URL=amqp://admin:password@localhost:5672
RABBITMQ_USERNAME=admin
RABBITMQ_PASSWORD=password

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production-use-long-random-string
JWT_EXPIRATION=24h

# Security
ENCRYPTION_KEY=your-32-character-encryption-key-change-this-in-production

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY=your-private-key
FIREBASE_CLIENT_EMAIL=your-client-email

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:19006

# API Configuration
API_VERSION=v1
API_PREFIX=/api

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_REGISTRATION_MAX=5
RATE_LIMIT_REGISTRATION_WINDOW_MS=900000
