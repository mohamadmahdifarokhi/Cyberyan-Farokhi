# Files to ignore during Render deployment

# Development files
*.md
!README.md
.git
.github
.vscode
.idea

# Test files
**/__tests__
**/*.test.ts
**/*.test.tsx
**/*.test.js
**/*.spec.ts
**/*.spec.js
**/tests
e2e/

# Documentation
docs/
DEMO_*.md
VISUAL_*.md
ENHANCED_*.md
FEATURE_*.md

# Local environment files
.env.local
.env.development
.env.test
*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# IDE
*.swp
*.swo
*~

# Temporary files
tmp/
temp/
*.tmp

# Build artifacts (will be rebuilt)
dist/
build/
web-build/
.expo/
.expo-shared/

# Dependencies (will be reinstalled)
node_modules/

# Docker files (not needed on Render)
docker-compose*.yml
Dockerfile.dev
*.dockerignore

# Load testing
load-tests/
security-audit/

# Mobile specific
ios/
android/
*.apk
*.ipa
